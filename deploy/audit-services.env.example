# Copy this file to /opt/audit/deploy/audit-services.env and fill real values.
# Keep this file readable only by the deployment user and root if it contains secrets.

# Time zone
TZ=Asia/Shanghai

# DashScope / Aliyun Bailian model API key.
# Uncomment and fill these values if you want to override application.yml.
# DASHSCOPE_API_KEY=sk-your-real-key
# AUDIT_EMBEDDING_API_KEY=sk-your-real-key

# Workflow temporary vector database.
AUDIT_VECTOR_JDBC_URL=jdbc:postgresql://127.0.0.1:5432/audit_vector
AUDIT_VECTOR_JDBC_USERNAME=audit_vector_user
AUDIT_VECTOR_JDBC_PASSWORD=301836

# Workflow OCR client.
AUDIT_OCR_ENDPOINT=http://127.0.0.1:8866/ocr
AUDIT_OCR_PROVIDER=paddle
AUDIT_OCR_TIMEOUT_SECONDS=600

# OCR service provider.
# Use "paddle" for local PaddleOCR, or "aliyun" for Aliyun OCR.
OCR_PROVIDER=paddle

# Aliyun OCR settings. Fill these only when OCR_PROVIDER=aliyun.
ALIYUN_OCR_API=general
ALIYUN_OCR_ENDPOINT=ocr-api.cn-hangzhou.aliyuncs.com
# ALIBABA_CLOUD_ACCESS_KEY_ID=your-access-key-id
# ALIBABA_CLOUD_ACCESS_KEY_SECRET=your-access-key-secret
