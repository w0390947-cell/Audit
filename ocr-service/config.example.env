# paddle/local: use local PaddleOCR.
# aliyun/cloud: use Aliyun OCR API.
OCR_PROVIDER=aliyun

# general: RecognizeGeneral
# advanced: RecognizeAdvanced
ALIYUN_OCR_API=general
ALIYUN_OCR_ENDPOINT=ocr-api.cn-hangzhou.aliyuncs.com
ALIYUN_CONNECT_TIMEOUT=600000
ALIYUN_READ_TIMEOUT=600000
ALIYUN_IMAGE_MAX_SIDE=2200
ALIYUN_IMAGE_MAX_BYTES=5242880
ALIYUN_JPEG_QUALITY=85

# Use a RAM user key with OCR permission. Do not commit real keys.
ALIBABA_CLOUD_ACCESS_KEY_ID=your_access_key_id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your_access_key_secret
